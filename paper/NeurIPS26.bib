@misc{khattakMaPLeMultimodalPrompt2023,
  title = {{{MaPLe}}: {{Multi-modal Prompt Learning}}},
  shorttitle = {{{MaPLe}}},
  author = {Khattak, Muhammad Uzair and Rasheed, Hanoona and Maaz, Muhammad and Khan, Salman and Khan, Fahad Shahbaz},
  year = 2023,
