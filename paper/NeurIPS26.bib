  keywords = {Computer Science - Artificial Intelligence,Computer Science - Computation and Language,Computer Science - Computer Vision and Pattern Recognition,Computer Science - Human-Computer Interaction,notion},
  file = {C\:\\Users\\Luke-\\Zotero\\storage\\P5SF4YWK\\Lim and Lee - 2024 - Measuring Visual Sycophancy in Multimodal Models.pdf;C\:\\Users\\Luke-\\Zotero\\storage\\Y4ZZ6CM3\\2408.html}
