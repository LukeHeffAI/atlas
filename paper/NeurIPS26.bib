@misc{linLearningModelWorld2023,
  title = {Learning to {{Model}} the {{World}} with {{Language}}},
  author = {Lin, Jessy and Du, Yuqing and Watkins, Olivia and Hafner, Danijar and Abbeel, Pieter and Klein, Dan and Dragan, Anca},
