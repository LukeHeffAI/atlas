@misc{menonVisualClassificationDescription2022a,
  title = {Visual {{Classification}} via {{Description}} from {{Large Language Models}}},
  author = {Menon, Sachit and Vondrick, Carl},
  year = 2022,
  month = dec,
  number = {arXiv:2210.07183},
